# Caption Compass provider mode.
# Copy this file to .env for local experiments.
# Never commit .env.

# Default deterministic mode. No network is used.
CAPTION_COMPASS_PROVIDER=stub

# Fireworks provider mode placeholders.
# Credentials alone are not enough for pixel/audio understanding until
# provider-backed vision/audio gates are implemented.
#
# CAPTION_COMPASS_PROVIDER=fireworks
# FIREWORKS_API_KEY=
# CAPTION_COMPASS_VISION_MODEL=replace-with-hackathon-vision-model
# CAPTION_COMPASS_TEXT_MODEL=replace-with-hackathon-text-model
# CAPTION_COMPASS_AUDIO_MODEL=replace-with-hackathon-audio-model

CAPTION_COMPASS_PROVIDER_TIMEOUT_SECONDS=60
